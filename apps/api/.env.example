ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://dashr:dashr@localhost:5432/dashr
JWT_SECRET=change-me-generate-with-python-secrets-token-hex-32
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
COOKIE_SECURE=false
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=dashr-cards
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
MAX_UPLOAD_FILE_SIZE_MB=10
MAX_BULK_UPLOAD_FILES=200
ALLOWED_CARD_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif
MAX_ARCHIVE_FILE_SIZE_MB=300
MAX_ARCHIVE_RAW_ENTRY_COUNT=2000
ALLOWED_ARCHIVE_CONTENT_TYPES=application/zip,application/x-zip-compressed,application/pdf
PDF_RENDER_DPI=200
MAX_PDF_PAGE_EDGE_PX=4000
ANTHROPIC_API_KEY=
VISION_MODEL=claude-sonnet-5
VISION_REQUEST_TIMEOUT_SECONDS=30
SUMMARY_MODEL=claude-sonnet-5
SUMMARY_REQUEST_TIMEOUT_SECONDS=15
